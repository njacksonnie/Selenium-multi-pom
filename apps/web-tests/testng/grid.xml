<!-- apps/web-tests/testng/grid.xml -->
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd" >
<suite name="Grid" parallel="tests" thread-count="6">
  <parameter name="runTarget" value="grid"/>
  <parameter name="gridUrl" value="http://localhost:4444/wd/hub"/>
  <parameter name="browser" value="chrome"/>
  <test name="Smoke">
    <classes>
      <class name="suites.SmokeSuite"/>
    </classes>
  </test>
</suite>
